# ============================================================
# .env.example - Template Environment Variables
# Salin ke Railway Dashboard → Variables
# JANGAN commit file .env ke GitHub!
# ============================================================

# ── WAJIB: Database (dari Railway PostgreSQL plugin) ─────────
# Railway otomatis mengisi ini jika tambah PostgreSQL plugin
DATABASE_URL=postgresql://user:password@host:5432/railway

# ── WAJIB: Pilih salah satu AI provider ─────────────────────

# Opsi A: Gemini (GRATIS, direkomendasikan)
# Dapatkan di: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# Opsi B: OpenAI (berbayar, skip jika pakai Gemini)
# OPENAI_API_KEY=sk-...

# ── OPSIONAL: Model AI ───────────────────────────────────────
# Default: gemini-2.0-flash (cepat & gratis)
# Pilihan: gemini-1.5-flash | gemini-1.5-pro | gemini-2.0-flash
AI_MODEL=gemini-2.0-flash

# ── WAJIB: Secret keys untuk autentikasi ────────────────────
# Generate: openssl rand -hex 32
NEXTAUTH_SECRET=ganti_dengan_random_string_panjang_32_karakter
JWT_SECRET=ganti_dengan_random_string_lain_32_karakter

# ── WAJIB: URL aplikasi (isi setelah dapat domain dari Railway)
# Contoh: https://paperclip-production.up.railway.app
NEXTAUTH_URL=https://YOUR_APP.up.railway.app
NEXT_PUBLIC_APP_URL=https://YOUR_APP.up.railway.app

# ── OPSIONAL: Port (Railway set otomatis) ───────────────────
# PORT=3000

# ── OPSIONAL: Node environment ──────────────────────────────
NODE_ENV=production
